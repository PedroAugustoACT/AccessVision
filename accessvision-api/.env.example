# Teste local sem gastar tokens: LLM_OFFLINE=true (ignora chaves abaixo)
LLM_OFFLINE=false
CURSOR_API_KEY=
CURSOR_MODEL_ID=composer-2
#cursor ou gemini
LLM_PROVIDER=gemini
GEMINI_API_KEY=
# Use o mesmo modelo que aparece no painel (ex.: gemini-2.5-flash).
GEMINI_MODEL_ID=gemini-2.5-flash
GEMINI_REQUEST_DELAY_SECONDS=12
CORS_ORIGINS=http://localhost:5173,https://access-vision-opal.vercel.app
MAX_UPLOAD_MB=50
LLM_TIMEOUT_SECONDS=180
